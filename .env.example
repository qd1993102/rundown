# Rundown 环境变量配置
# 复制此文件为 .env 并填入真实值

# Garmin Connect 国际区登录邮箱（必填）
GARMIN_EMAIL=your_email@gmail.com

# Garmin Connect 登录密码（必填）
GARMIN_PASSWORD=your_password

# API 域名（国际区默认，中国区用 garmin.cn）
GARMIN_DOMAIN=garmin.com

# Token 持久化目录
GARMIN_TOKEN_DIR=~/.garmy

# SQLite 数据库路径
GARMIN_DB_PATH=./data/garmin_data.db

# 默认同步最近 N 天的数据
GARMIN_SYNC_DAYS=30

# 日志级别: DEBUG | INFO | WARNING | ERROR
GARMIN_LOG_LEVEL=INFO

# DeepSeek API Key（可选，启用 AI 教练洞察）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
