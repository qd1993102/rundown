# Rundown 环境变量配置
# 复制此文件为 .env 并填入真实值
# 兼容旧名 GARMIN_EMAIL / GARMIN_PASSWORD，推荐用新的 RUNDOWN_ 前缀

# ── 必填（Garmin 和 Coros 通用）──
RUNDOWN_EMAIL=your_email@gmail.com
RUNDOWN_PASSWORD=your_password

# ── 数据源: garmin（默认）| coros ──
RUNDOWN_PROVIDER=garmin

# ── 数据库 ──
RUNDOWN_DB_PATH=./data/rundown_data.db
RUNDOWN_SYNC_DAYS=30
RUNDOWN_LOG_LEVEL=INFO

# ── Garmin 专用 ──
# GARMIN_DOMAIN=garmin.com
# GARMIN_TOKEN_DIR=~/.garmy

# ── Coros 专用 ──
# 无需额外配置，邮箱密码同上

# ── AI 教练（可选）──
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
